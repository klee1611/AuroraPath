# ─── Auth0 (User Auth) ─────────────────────────────────────────────────────
# Create an Auth0 application (Regular Web Application) at https://auth0.com
AUTH0_SECRET=use-openssl-rand-hex-32-to-generate-this
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_AUTH0_DOMAIN.auth0.com
AUTH0_CLIENT_ID=your_auth0_spa_client_id
AUTH0_CLIENT_SECRET=your_auth0_spa_client_secret

# ─── Auth0 M2M (Agent Identity for Gemini Orchestrator) ────────────────────
# Create a Machine-to-Machine application in Auth0 for the AI agent
AUTH0_M2M_CLIENT_ID=your_auth0_m2m_client_id
AUTH0_M2M_CLIENT_SECRET=your_auth0_m2m_client_secret
AUTH0_M2M_AUDIENCE=https://YOUR_AUTH0_DOMAIN.auth0.com/api/v2/

# ─── Google Gemini ──────────────────────────────────────────────────────────
# Get your API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ─── Per-User Quota (Upstash Redis) ────────────────────────────────────────
# Limits each logged-in user to DAILY_GEMINI_LIMIT Gemini calls per day.
# Without these, an in-memory fallback is used (not shared across serverless instances).
# Create a free Redis database at https://upstash.com (free tier: 10k commands/day)
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
# Daily Gemini calls allowed per user (default: 5)
DAILY_GEMINI_LIMIT=5

# ─── Map Tiles (Optional – Stadia Maps) ────────────────────────────────────
# Free tier at https://stadiamaps.com — no key required for development
# Add a key here for production to unlock higher rate limits
NEXT_PUBLIC_STADIA_API_KEY=
